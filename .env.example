# --- Образ (для деплоя через GHCR) ---
# Заполняется в CI/на сервере; для локальной сборки можно не задавать (используется build: .)
APP_IMAGE=ghcr.io/<owner>/kp-msx:latest

# --- Базовое ---
# Внешний адрес сервера, подставляется во все ссылки MSX. БЕЗ него ссылки сломаны.
# Формат: http(s)://<IP_или_домен>:<HOST_PORT>
MSX_HOST=http://127.0.0.1:1234

# Порт внутри контейнера (config.PORT). Менять обычно не нужно.
PORT=10000
# Порт на хосте, проброшенный наружу.
HOST_PORT=1234

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=kpmsx
MONGO_INITDB_ROOT_PASSWORD=change-me
# Строка подключения приложения к контейнеру mongo (хост = имя сервиса "mongo").
MONGODB_URL=mongodb://kpmsx:change-me@mongo:27017/?authSource=admin
MONGODB_COLLECTION=kp

# --- Плеер / протокол (опционально, есть дефолты в config.py) ---
# PLAYER=https://slonopot.github.io/msx-hlsx/hlsx.html
# ALTERNATIVE_PLAYER=http://msx.benzac.de/plugins/html5x.html
# PROTOCOL=hls4
# QUALITY=
# TIZEN=

# --- OAuth кинопаба (опционально, есть дефолты) ---
# KP_CLIENT_ID=
# KP_CLIENT_SECRET=
